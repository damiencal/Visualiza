# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=visualiza
DB_USER=visualiza
DB_PASSWORD=password
DB_ROOT_PASSWORD=rootpassword

# Async URL (used by app at runtime)
DATABASE_URL=mysql+aiomysql://visualiza:password@localhost:3306/visualiza

# Sync URL (used by Alembic migrations)
SYNC_DATABASE_URL=mysql+pymysql://visualiza:password@localhost:3306/visualiza

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_HEX_CHARS

# ─── CORS ─────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3001","http://localhost:3002","http://localhost:8000"]

# ─── Storage (MinIO / S3) ─────────────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=visualiza
S3_REGION=us-east-1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_STARTER_PRICE_ID=price_REPLACE_ME
STRIPE_PROFESSIONAL_PRICE_ID=price_REPLACE_ME
STRIPE_ENTERPRISE_PRICE_ID=price_REPLACE_ME

# ─── Nuxt / Frontend URLs ─────────────────────────────────────────────────────
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Used by portal for Stripe success/cancel redirect URLs
PORTAL_URL=http://localhost:3002
NUXT_PUBLIC_APP_URL=http://localhost:3002

# ─── Superadmin seed credentials ─────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@visualiza.do
SEED_ADMIN_PASSWORD=Admin1234!
